# ================================
# Claude Code Web - 環境変数
# ================================
# このファイルを .env.local にコピーして各値を設定してください
# Vercel では Dashboard > Settings > Environment Variables で設定

# --- Claude API ---
# Anthropic Console (console.anthropic.com) で取得
CLAUDE_API_KEY=sk-ant-...

# --- 認証 ---
# ランダムな32文字以上の文字列（例: openssl rand -base64 32 で生成）
AUTH_SECRET=your-random-secret-here

# --- WebAuthn (Face ID) ---
# ローカル開発: localhost
# Vercel本番: your-app.vercel.app（https:// は不要）
WEBAUTHN_RP_ID=localhost

# ローカル開発: http://localhost:3000
# Vercel本番: https://your-app.vercel.app
WEBAUTHN_ORIGIN=http://localhost:3000

# 初回セットアップ時のパスワード（自分だけ知っている文字列）
# セットアップ完了後は削除してもOK
SETUP_SECRET=your-setup-password

# --- Face ID 登録情報 ---
# /setup ページでFace IDを登録後、表示されるJSONをここに貼り付ける
# 初回は空のまま → /setup にアクセスして登録
WEBAUTHN_CREDENTIAL=
